<view wx:if="{{visible}}" class="sheet-mask" catchtap="onSkip"></view>
<view wx:if="{{visible}}" class="sheet">
  <view class="sheet-handle"></view>
  <view class="sheet-head">
    <view class="sheet-title-wrap">
      <view class="sheet-icon">👁</view>
      <view>
        <view class="sheet-title">{{guide.title}}</view>
        <view class="sheet-subtitle">{{guide.subtitle}}</view>
      </view>
    </view>
    <button class="sheet-close" bindtap="onSkip">×</button>
  </view>

  <view class="guide-hero">
    <view class="hero-person">
      <view class="hero-head"></view>
      <view class="hero-body"></view>
    </view>
    <view class="hero-window">
      <view class="hero-sky"></view>
      <view class="hero-hill"></view>
    </view>
    <view class="hero-bubble">{{guide.heroText}}</view>
  </view>

  <view class="guide-steps">
    <view class="guide-step" wx:for="{{guide.steps}}" wx:key="title">
      <view class="step-icon">{{item.icon}}</view>
      <view class="step-title">{{index + 1}}. {{item.title}}</view>
      <view class="step-detail">{{item.detail}}</view>
    </view>
  </view>

  <view class="guide-timer">
    <view class="timer-ring">{{guide.durationLabel}}</view>
  </view>

  <view class="sheet-actions">
    <button class="skip-button" bindtap="onSkip">跳过</button>
    <button class="start-button" bindtap="onStart">开始 20s 护眼操</button>
  </view>
</view>
