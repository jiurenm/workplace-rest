<view class="summary-list">
  <view class="summary-card" wx:for="{{items}}" wx:key="taskType">
    <view class="summary-icon" style="background: {{item.lightColor}}; color: {{item.color}};">{{item.icon}}</view>
    <view class="summary-main">
      <view class="summary-top">
        <view class="summary-name">{{item.title}}</view>
        <view class="summary-count" style="color: {{item.color}};">
          {{item.completed}} <text class="summary-total">/ {{item.target}} 次</text>
        </view>
      </view>
      <view class="summary-progress">
        <view class="summary-progress-bar" style="width: {{item.progressPercent}}%; background: {{item.color}};"></view>
      </view>
    </view>
    <view class="summary-next">{{item.nextReminderLabel}}</view>
  </view>
</view>
