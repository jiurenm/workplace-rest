.summary-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.summary-card {
  display: flex;
  min-height: 116rpx;
  align-items: center;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(31, 44, 71, 0.06);
}

.summary-icon {
  display: flex;
  width: 62rpx;
  height: 62rpx;
  flex: 0 0 62rpx;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 36rpx;
}

.summary-main {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-name {
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.summary-count {
  font-size: 30rpx;
  font-weight: 800;
}

.summary-total {
  color: #344054;
  font-size: 24rpx;
  font-weight: 500;
}

.summary-progress {
  height: 10rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #edf1f7;
}

.summary-progress-bar {
  height: 100%;
  border-radius: 999rpx;
}

.summary-next {
  width: 112rpx;
  color: #8a94a6;
  font-size: 22rpx;
  line-height: 1.4;
  text-align: right;
}
