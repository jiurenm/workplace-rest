.countdown-shell {
  display: flex;
  justify-content: center;
  padding: 22rpx 0 8rpx;
}

.ring {
  width: 480rpx;
  height: 480rpx;
  padding: 20rpx;
  border-radius: 50%;
  box-shadow: 0 20rpx 44rpx rgba(47, 123, 255, 0.12);
}

.ring-inner {
  display: flex;
  width: 100%;
  height: 100%;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
}

.task-icon {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 44rpx;
}

.ring-label {
  margin-top: 28rpx;
  color: #344054;
  font-size: 26rpx;
}

.ring-time {
  margin-top: 8rpx;
  color: #101828;
  font-size: 78rpx;
  font-weight: 800;
  line-height: 1;
}

.ring-hint {
  margin-top: 24rpx;
  color: #98a2b3;
  font-size: 24rpx;
}
