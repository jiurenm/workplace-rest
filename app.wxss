page {
  min-height: 100vh;
  color: #23211f;
  background: #f7f4ef;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-note {
  margin-top: 16rpx;
  color: #7b756c;
  font-size: 28rpx;
  line-height: 1.6;
}
