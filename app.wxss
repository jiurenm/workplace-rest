page {
  min-height: 100vh;
  color: #101828;
  background: #f6f8fc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-note {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.card {
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(31, 44, 71, 0.06);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #101828;
}

.muted {
  color: #8a94a6;
}
