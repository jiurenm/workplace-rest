.settings-header {
  display: flex;
  height: 56rpx;
  align-items: center;
  justify-content: space-between;
}

.back-icon,
.header-spacer {
  width: 56rpx;
}

.back-icon {
  color: #101828;
  font-size: 56rpx;
  line-height: 52rpx;
}

.settings-title {
  color: #101828;
  font-size: 32rpx;
  font-weight: 800;
}

.desktop-card {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #5aa0ff, #2f7bff);
  box-shadow: 0 18rpx 38rpx rgba(47, 123, 255, 0.24);
}

.phone-icon {
  display: flex;
  width: 72rpx;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.16);
}

.phone-drop {
  font-size: 32rpx;
}

.desktop-copy {
  flex: 1;
  margin-left: 22rpx;
}

.desktop-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.desktop-note {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
}

.desktop-arrow,
.row-arrow {
  color: #98a2b3;
  font-size: 48rpx;
}

.desktop-arrow {
  color: #ffffff;
}

.setting-card {
  margin-top: 24rpx;
  padding: 24rpx;
}

.setting-row {
  display: flex;
  align-items: center;
}

.setting-icon {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  align-items: center;
  justify-content: center;
  color: #101828;
  font-size: 30rpx;
}

.setting-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.setting-label {
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.setting-value {
  margin-top: 20rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 600;
}

.setting-note {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 23rpx;
  line-height: 1.45;
}

.settings-section-title {
  margin: 34rpx 0 16rpx;
  color: #101828;
  font-size: 26rpx;
  font-weight: 800;
}

.reminder-card {
  padding: 4rpx 24rpx;
}

.reminder-row {
  display: flex;
  min-height: 96rpx;
  align-items: center;
  border-bottom: 1rpx solid #edf1f7;
}

.reminder-row:last-child {
  border-bottom: 0;
}

.reminder-left {
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: center;
}

.reminder-icon {
  width: 46rpx;
  flex: 0 0 46rpx;
  font-size: 34rpx;
}

.reminder-title {
  margin-left: 14rpx;
  color: #101828;
  font-size: 27rpx;
  font-weight: 600;
}

.reminder-meta {
  width: 148rpx;
  color: #8a94a6;
  font-size: 23rpx;
  text-align: right;
}

switch {
  margin-left: 18rpx;
  transform: scale(0.78);
  transform-origin: right center;
}
