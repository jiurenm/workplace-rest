<view class="page home-page" wx:if="{{dashboard}}">
  <view class="home-header">
    <view>
      <view class="page-title">健康提醒</view>
      <view class="page-note">{{dashboard.healthScore}}</view>
    </view>
  </view>

  <countdown-ring task="{{dashboard.currentTask}}" bind:ringtap="onShowGuide" />

  <view class="quick-actions">
    <button class="quick-button pause-button" bindtap="onTogglePause">
      <text class="quick-icon">{{paused ? '▶' : 'Ⅱ'}}</text>
      <text>{{paused ? '继续计时' : '暂停计时'}}</text>
    </button>
    <button class="quick-button checkin-button" bindtap="onQuickCheckin">
      <text class="check-mark">✓</text>
      <text>{{dashboard.currentTask.actionLabel}}</text>
    </button>
  </view>

  <view class="overview-head">
    <view class="section-title">今日健康概览</view>
    <view class="overview-note">点击切换，长按调整</view>
  </view>

  <task-summary
    items="{{dashboard.tasks}}"
    selected="{{dashboard.currentTask.taskType}}"
    bind:select="onSelectTask"
    bind:adjust="onAdjustTask"
  />

  <action-guide-sheet
    visible="{{sheetVisible}}"
    guide="{{dashboard.guide}}"
    bind:skip="onHideGuide"
    bind:start="onStartGuide"
  />
</view>
