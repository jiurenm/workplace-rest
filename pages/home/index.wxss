.home-page {
  padding-bottom: 72rpx;
}

.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.more-button {
  width: 88rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #101828;
  font-size: 34rpx;
  line-height: 52rpx;
  box-shadow: 0 10rpx 26rpx rgba(31, 44, 71, 0.08);
}

.task-switcher {
  width: 100%;
  margin-top: 10rpx;
  white-space: nowrap;
}

.task-chip {
  display: inline-flex;
  height: 62rpx;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 0 20rpx;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  background: #ffffff;
  color: #667085;
  font-size: 24rpx;
  line-height: 62rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 44, 71, 0.05);
}

.task-chip-active {
  background: #f7fbff;
  font-weight: 700;
}

.chip-icon {
  margin-right: 8rpx;
}

.quick-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-button {
  display: flex;
  height: 92rpx;
  flex: 1;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.pause-button {
  border: 2rpx solid #d6e4ff;
  background: #ffffff;
  color: #2f7bff;
}

.checkin-button {
  background: linear-gradient(135deg, #4b8cff, #2f7bff);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(47, 123, 255, 0.24);
}

.quick-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.check-mark {
  display: flex;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #2f7bff;
  font-size: 30rpx;
  line-height: 42rpx;
}

.overview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 36rpx 0 18rpx;
}

.overview-note {
  color: #8a94a6;
  font-size: 22rpx;
}

.guide-entry {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 24rpx;
}

.guide-entry-icon {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #d9f5e5;
  font-size: 36rpx;
}

.guide-entry-text {
  flex: 1;
  margin-left: 18rpx;
}

.guide-entry-title {
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.guide-entry-note {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.guide-entry-arrow {
  color: #98a2b3;
  font-size: 48rpx;
}
