.home-page {
  padding-bottom: 72rpx;
}

.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quick-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-button {
  display: flex;
  height: 92rpx;
  flex: 1;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.pause-button {
  border: 2rpx solid #d6e4ff;
  background: #ffffff;
  color: #2f7bff;
}

.checkin-button {
  background: linear-gradient(135deg, #4b8cff, #2f7bff);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(47, 123, 255, 0.24);
}

.quick-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.check-mark {
  display: flex;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #2f7bff;
  font-size: 30rpx;
  line-height: 42rpx;
}

.overview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 36rpx 0 18rpx;
}

.overview-note {
  color: #8a94a6;
  font-size: 22rpx;
}
