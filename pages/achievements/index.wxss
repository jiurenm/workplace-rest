.achievements-page {
  padding-bottom: 140rpx;
}

.achievement-nav {
  display: flex;
  height: 58rpx;
  align-items: center;
  justify-content: space-between;
}

.back-button,
.nav-spacer {
  width: 58rpx;
  height: 58rpx;
}

.back-button {
  color: #101828;
  font-size: 58rpx;
  line-height: 52rpx;
}

.nav-title {
  color: #101828;
  font-size: 32rpx;
  font-weight: 800;
}

.earned-card {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff7e8, #ffffff);
  box-shadow: 0 16rpx 40rpx rgba(255, 159, 28, 0.12);
}

.medal {
  display: flex;
  width: 108rpx;
  height: 108rpx;
  flex: 0 0 108rpx;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #ffcf62;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffd778, #ff9f1c);
  color: #ffffff;
  font-size: 58rpx;
  box-shadow: 0 14rpx 24rpx rgba(255, 159, 28, 0.24);
}

.earned-copy {
  margin-left: 22rpx;
}

.earned-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
}

.earned-note {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 23rpx;
}

.achievement-tabs {
  display: flex;
  height: 56rpx;
  margin-top: 30rpx;
  padding: 5rpx;
  border-radius: 999rpx;
  background: #eef2f8;
}

.achievement-tab {
  flex: 1;
  border-radius: 999rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 46rpx;
}

.achievement-tab-active {
  background: #ffffff;
  color: #101828;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(31, 44, 71, 0.08);
}

.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 36rpx 18rpx;
  margin-top: 40rpx;
}

.badge-item {
  min-height: 196rpx;
  text-align: center;
}

.badge-icon {
  display: flex;
  width: 112rpx;
  height: 112rpx;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  border: 8rpx solid #ffd778;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffda7a, #ff9f1c);
  color: #ffffff;
  font-size: 56rpx;
  box-shadow: 0 14rpx 24rpx rgba(255, 159, 28, 0.2);
}

.badge-icon-locked {
  border-color: #d8dee9;
  background: linear-gradient(145deg, #eef2f8, #cfd6e3);
  color: #ffffff;
  box-shadow: none;
}

.badge-name {
  margin-top: 14rpx;
  color: #101828;
  font-size: 24rpx;
  font-weight: 800;
}

.badge-condition {
  margin-top: 6rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.35;
}

.poster-button {
  position: fixed;
  right: 28rpx;
  bottom: 42rpx;
  left: 28rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4b8cff, #2f7bff);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
  box-shadow: 0 16rpx 32rpx rgba(47, 123, 255, 0.24);
}

.poster-icon {
  margin-right: 10rpx;
}
